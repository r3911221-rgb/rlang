#include "bytecode/compiler.h"
#include <stdexcept>

namespace r::vm {

Compiler::Compiler(Chunk* chunk) : chunk_(chunk), scopeDepth_(0) {}

void Compiler::emit(uint8_t byte) {
    chunk_->write(byte, 1);
}

void Compiler::emit(OpCode op) {
    chunk_->write(op, 1);
}

void Compiler::emit(OpCode op, uint8_t operand) {
    chunk_->write(op, 1);
    chunk_->write(operand, 1);
}

size_t Compiler::emitJump(OpCode op) {
    emit(op);
    emit(0xff);
    emit(0xff);
    return chunk_->count() - 2;
}

void Compiler::patchJump(size_t offset) {
    size_t jump = chunk_->count() - offset - 2;
    if (jump > 65535) throw std::runtime_error("Too much code to jump over.");
    chunk_->code[offset] = (jump >> 8) & 0xff;
    chunk_->code[offset + 1] = jump & 0xff;
}

void Compiler::emitLoop(size_t loopStart) {
    emit(OpCode::OP_LOOP);
    size_t offset = chunk_->count() - loopStart + 2;
    if (offset > 65535) throw std::runtime_error("Loop body too large.");
    emit((offset >> 8) & 0xff);
    emit(offset & 0xff);
}

void Compiler::emitConstant(const Value& value) {
    emit(OpCode::OP_CONST);
    emit(static_cast<uint8_t>(makeConstant(value)));
}

size_t Compiler::makeConstant(const Value& value) {
    return chunk_->addConstant(value);
}

void Compiler::emitReturn() {
    emit(OpCode::OP_RETURN);
}

void Compiler::beginScope() {
    scopeDepth_++;
}

void Compiler::endScope() {
    scopeDepth_--;
    while (!locals_.empty() && locals_.back().depth > scopeDepth_) {
        emit(OpCode::OP_POP);
        locals_.pop_back();
    }
}

int Compiler::resolveLocal(const std::string& name) {
    for (int i = static_cast<int>(locals_.size()) - 1; i >= 0; --i) {
        if (locals_[i].name == name) return i;
    }
    return -1;
}

void Compiler::addLocal(const std::string& name, bool isMutable) {
    locals_.push_back({name, scopeDepth_, isMutable});
}

void Compiler::declareVariable(const std::string& name, bool isMutable) {
    if (scopeDepth_ == 0) return;
    for (auto it = locals_.rbegin(); it != locals_.rend(); ++it) {
        if (it->depth != -1 && it->depth < scopeDepth_) break;
        if (it->name == name) throw std::runtime_error("Variable already declared.");
    }
    addLocal(name, isMutable);
}

void Compiler::defineVariable(const std::string& name) {
    if (scopeDepth_ > 0) return;
    emitConstant(Value::string_(name));
    emit(OpCode::OP_DEFINE_GLOBAL);
}

void Compiler::namedVariable(const std::string& name, bool canAssign) {
    int arg = resolveLocal(name);
    if (arg != -1) {
        if (canAssign) {
            emit(OpCode::OP_SET_LOCAL);
            emit(static_cast<uint8_t>(arg));
        } else {
            emit(OpCode::OP_GET_LOCAL);
            emit(static_cast<uint8_t>(arg));
        }
    } else {
        emitConstant(Value::string_(name));
        if (canAssign) {
            emit(OpCode::OP_SET_GLOBAL);
        } else {
            emit(OpCode::OP_GET_GLOBAL);
        }
    }
}

void Compiler::compile(ast::Program* program) {
    for (auto& item : program->items) {
        compileItem(item.get());
    }
    emit(OpCode::OP_NIL);
    emit(OpCode::OP_RETURN);
}

void Compiler::compileItem(ast::Item* item) {
    if (auto* func = dynamic_cast<ast::FunctionItem*>(item)) compileFunction(func);
    else if (auto* let = dynamic_cast<ast::LetItem*>(item)) compileLetItem(let);
    else if (auto* con = dynamic_cast<ast::ConstItem*>(item)) compileConstItem(con);
}

void Compiler::compileFunction(ast::FunctionItem* func) {
    if (func->name == "main") {
        for (auto& stmt : func->body->stmts) {
            compileStmt(stmt.get());
        }
    }
}

void Compiler::compileLetItem(ast::LetItem* item) {
    compileExpr(item->value.get());
    declareVariable(item->name, item->isMut);
    defineVariable(item->name);
}

void Compiler::compileConstItem(ast::ConstItem* item) {
    compileExpr(item->value.get());
    declareVariable(item->name, false);
    defineVariable(item->name);
}

void Compiler::compileStmt(ast::Stmt* stmt) {
    if (auto* let = dynamic_cast<ast::LetStmt*>(stmt)) compileLetStmt(let);
    else if (auto* con = dynamic_cast<ast::ConstStmt*>(stmt)) compileConstStmt(con);
    else if (auto* expr = dynamic_cast<ast::ExprStmt*>(stmt)) compileExprStmt(expr);
    else if (auto* ifs = dynamic_cast<ast::IfStmt*>(stmt)) compileIfStmt(ifs);
    else if (auto* wh = dynamic_cast<ast::WhileStmt*>(stmt)) compileWhileStmt(wh);
    else if (auto* fr = dynamic_cast<ast::ForStmt*>(stmt)) compileForStmt(fr);
    else if (auto* ret = dynamic_cast<ast::ReturnStmt*>(stmt)) compileReturnStmt(ret);
    else if (auto* br = dynamic_cast<ast::BreakStmt*>(stmt)) compileBreakStmt(br);
    else if (auto* con = dynamic_cast<ast::ContinueStmt*>(stmt)) compileContinueStmt(con);
}

void Compiler::compileLetStmt(ast::LetStmt* stmt) {
    compileExpr(stmt->value.get());
    declareVariable(stmt->name, stmt->isMut);
    defineVariable(stmt->name);
}

void Compiler::compileConstStmt(ast::ConstStmt* stmt) {
    compileExpr(stmt->value.get());
    declareVariable(stmt->name, false);
    defineVariable(stmt->name);
}

void Compiler::compileExprStmt(ast::ExprStmt* stmt) {
    compileExpr(stmt->expr.get());
    emit(OpCode::OP_POP);
}

void Compiler::compileIfStmt(ast::IfStmt* stmt) {
    compileExpr(stmt->condition.get());
    size_t thenJump = emitJump(OpCode::OP_JUMP_IF_FALSE);
    emit(OpCode::OP_POP);
    compileBlock(stmt->thenBranch.get());
    if (stmt->elseBranch) {
        size_t elseJump = emitJump(OpCode::OP_JUMP);
        patchJump(thenJump);
        emit(OpCode::OP_POP);
        if (auto* elseBlock = dynamic_cast<ast::BlockExpr*>(stmt->elseBranch.get())) {
            compileBlock(elseBlock);
        } else if (auto* elseIf = dynamic_cast<ast::IfStmt*>(stmt->elseBranch.get())) {
            compileIfStmt(elseIf);
        }
        patchJump(elseJump);
    } else {
        patchJump(thenJump);
        emit(OpCode::OP_POP);
    }
}

void Compiler::compileWhileStmt(ast::WhileStmt* stmt) {
    size_t loopStart = chunk_->count();
    compileExpr(stmt->condition.get());
    size_t exitJump = emitJump(OpCode::OP_JUMP_IF_FALSE);
    emit(OpCode::OP_POP);

    size_t breakStart = breakJumps_.size();
    size_t continueStart = continueStarts_.size();
    continueStarts_.push_back(loopStart);

    beginScope();
    for (auto& s : stmt->body->stmts) compileStmt(s.get());
    endScope();

    emitLoop(loopStart);
    patchJump(exitJump);
    emit(OpCode::OP_POP);

    for (size_t i = breakStart; i < breakJumps_.size(); ++i) {
        patchJump(breakJumps_[i]);
    }
    breakJumps_.resize(breakStart);
    continueStarts_.resize(continueStart);
}

void Compiler::compileForStmt(ast::ForStmt* stmt) {
    beginScope();

    emitConstant(Value::int_(0));
    declareVariable("__idx__", false);
    defineVariable("__idx__");

    compileExpr(stmt->iterable.get());
    declareVariable("__iter__", false);
    defineVariable("__iter__");

    size_t loopStart = chunk_->count();
    size_t breakStart = breakJumps_.size();
    size_t continueStart = continueStarts_.size();

    namedVariable("__idx__", false);
    namedVariable("__iter__", false);
    emitConstant(Value::string_("length"));
    emit(OpCode::OP_INDEX);
    emit(OpCode::OP_LT);

    size_t exitJump = emitJump(OpCode::OP_JUMP_IF_FALSE);
    emit(OpCode::OP_POP);

    namedVariable("__iter__", false);
    namedVariable("__idx__", false);
    emit(OpCode::OP_INDEX);
    declareVariable(stmt->varName, false);
    defineVariable(stmt->varName);

    for (auto& s : stmt->body->stmts) compileStmt(s.get());

    size_t incrementStart = chunk_->count();
    continueStarts_.push_back(incrementStart);

    emit(OpCode::OP_GET_LOCAL);
    emit(static_cast<uint8_t>(resolveLocal("__idx__")));
    emitConstant(Value::int_(1));
    emit(OpCode::OP_ADD);
    emit(OpCode::OP_SET_LOCAL);
    emit(static_cast<uint8_t>(resolveLocal("__idx__")));
    emit(OpCode::OP_POP);

    emitLoop(loopStart);
    patchJump(exitJump);
    emit(OpCode::OP_POP);

    for (size_t i = breakStart; i < breakJumps_.size(); ++i) {
        patchJump(breakJumps_[i]);
    }
    breakJumps_.resize(breakStart);
    continueStarts_.resize(continueStart);

    endScope();
}

void Compiler::compileReturnStmt(ast::ReturnStmt* stmt) {
    if (stmt->value) compileExpr(stmt->value.get());
    else emit(OpCode::OP_NIL);
    emit(OpCode::OP_RETURN);
}

void Compiler::compileBreakStmt(ast::BreakStmt*) {
    size_t jump = emitJump(OpCode::OP_JUMP);
    breakJumps_.push_back(jump);
}

void Compiler::compileContinueStmt(ast::ContinueStmt*) {
    if (continueStarts_.empty()) throw std::runtime_error("Continue outside loop.");
    emitLoop(continueStarts_.back());
}

void Compiler::compileExpr(ast::Expr* expr) {
    if (auto* lit = dynamic_cast<ast::LiteralExpr*>(expr)) compileLiteral(lit);
    else if (auto* ident = dynamic_cast<ast::IdentifierExpr*>(expr)) compileIdentifier(ident);
    else if (auto* bin = dynamic_cast<ast::BinaryExpr*>(expr)) compileBinary(bin);
    else if (auto* unary = dynamic_cast<ast::UnaryExpr*>(expr)) compileUnary(unary);
    else if (auto* call = dynamic_cast<ast::CallExpr*>(expr)) compileCall(call);
    else if (auto* field = dynamic_cast<ast::FieldExpr*>(expr)) compileField(field);
    else if (auto* index = dynamic_cast<ast::IndexExpr*>(expr)) compileIndex(index);
    else if (auto* block = dynamic_cast<ast::BlockExpr*>(expr)) compileBlock(block);
    else if (auto* ifExpr = dynamic_cast<ast::IfExpr*>(expr)) compileIf(ifExpr);
    else if (auto* match = dynamic_cast<ast::MatchExpr*>(expr)) compileMatch(match);
    else if (auto* arr = dynamic_cast<ast::ArrayExpr*>(expr)) compileArray(arr);
    else if (auto* range = dynamic_cast<ast::RangeExpr*>(expr)) compileRange(range);
    else if (auto* assign = dynamic_cast<ast::AssignExpr*>(expr)) compileAssign(assign);
}

void Compiler::compileLiteral(ast::LiteralExpr* lit) {
    switch (lit->kind) {
        case ast::LiteralExpr::Kind::Int: emitConstant(Value::int_(std::stoll(lit->value))); break;
        case ast::LiteralExpr::Kind::Float: emitConstant(Value::float_(std::stod(lit->value))); break;
        case ast::LiteralExpr::Kind::String: emitConstant(Value::string_(lit->value)); break;
        case ast::LiteralExpr::Kind::Bool: emitConstant(Value::bool_(lit->value == "true")); break;
        case ast::LiteralExpr::Kind::Nil: emit(OpCode::OP_NIL); break;
    }
}

void Compiler::compileIdentifier(ast::IdentifierExpr* ident) {
    namedVariable(ident->name, false);
}

void Compiler::compileBinary(ast::BinaryExpr* bin) {
    compileExpr(bin->left.get());
    compileExpr(bin->right.get());
    switch (bin->op) {
        case ast::BinaryExpr::Op::Add: emit(OpCode::OP_ADD); break;
        case ast::BinaryExpr::Op::Sub: emit(OpCode::OP_SUB); break;
        case ast::BinaryExpr::Op::Mul: emit(OpCode::OP_MUL); break;
        case ast::BinaryExpr::Op::Div: emit(OpCode::OP_DIV); break;
        case ast::BinaryExpr::Op::Mod: emit(OpCode::OP_MOD); break;
        case ast::BinaryExpr::Op::Eq: emit(OpCode::OP_EQ); break;
        case ast::BinaryExpr::Op::Neq: emit(OpCode::OP_NEQ); break;
        case ast::BinaryExpr::Op::Lt: emit(OpCode::OP_LT); break;
        case ast::BinaryExpr::Op::Gt: emit(OpCode::OP_GT); break;
        case ast::BinaryExpr::Op::Leq: emit(OpCode::OP_LEQ); break;
        case ast::BinaryExpr::Op::Geq: emit(OpCode::OP_GEQ); break;
        case ast::BinaryExpr::Op::And: emit(OpCode::OP_AND); break;
        case ast::BinaryExpr::Op::Or: emit(OpCode::OP_OR); break;
        case ast::BinaryExpr::Op::BitAnd: emit(OpCode::OP_BIT_AND); break;
        case ast::BinaryExpr::Op::BitOr: emit(OpCode::OP_BIT_OR); break;
        case ast::BinaryExpr::Op::BitXor: emit(OpCode::OP_BIT_XOR); break;
        case ast::BinaryExpr::Op::Shl: emit(OpCode::OP_SHL); break;
        case ast::BinaryExpr::Op::Shr: emit(OpCode::OP_SHR); break;
        case ast::BinaryExpr::Op::Assign: emit(OpCode::OP_POP); break;
        case ast::BinaryExpr::Op::Range: emit(OpCode::OP_RANGE); break;
        case ast::BinaryExpr::Op::RangeInclusive: emit(OpCode::OP_RANGE); break;
    }
}

void Compiler::compileUnary(ast::UnaryExpr* unary) {
    compileExpr(unary->operand.get());
    switch (unary->op) {
        case ast::UnaryExpr::Op::Neg: emit(OpCode::OP_NEG); break;
        case ast::UnaryExpr::Op::Not: emit(OpCode::OP_NOT); break;
        case ast::UnaryExpr::Op::BitNot: emit(OpCode::OP_BIT_NOT); break;
    }
}

void Compiler::compileCall(ast::CallExpr* call) {
    for (auto& arg : call->args) {
        compileExpr(arg.get());
    }
    compileExpr(call->callee.get());
    emit(OpCode::OP_CALL);
    emit(static_cast<uint8_t>(call->args.size()));
}

void Compiler::compileField(ast::FieldExpr* field) {
    compileExpr(field->object.get());
    emitConstant(Value::string_(field->field));
    emit(OpCode::OP_INDEX);
}

void Compiler::compileIndex(ast::IndexExpr* index) {
    compileExpr(index->object.get());
    compileExpr(index->index.get());
    emit(OpCode::OP_INDEX);
}

void Compiler::compileBlock(ast::BlockExpr* block) {
    beginScope();
    for (auto& stmt : block->stmts) {
        compileStmt(stmt.get());
    }
    endScope();
}

void Compiler::compileIf(ast::IfExpr* ifExpr) {
    compileExpr(ifExpr->condition.get());
    size_t thenJump = emitJump(OpCode::OP_JUMP_IF_FALSE);
    emit(OpCode::OP_POP);
    compileBlock(ifExpr->thenBranch.get());
    if (ifExpr->elseBranch) {
        size_t elseJump = emitJump(OpCode::OP_JUMP);
        patchJump(thenJump);
        emit(OpCode::OP_POP);
        compileExpr(ifExpr->elseBranch.get());
        patchJump(elseJump);
    } else {
        patchJump(thenJump);
        emit(OpCode::OP_POP);
    }
}

void Compiler::compileMatch(ast::MatchExpr* match) {
    compileExpr(match->scrutinee.get());
    size_t endJumps[64];
    size_t endCount = 0;
    bool hasWildcard = false;

    for (auto& arm : match->arms) {
        if (dynamic_cast<ast::WildcardPattern*>(arm.pattern.get()) ||
            dynamic_cast<ast::IdentifierPattern*>(arm.pattern.get())) {
            hasWildcard = true;
            compileExpr(arm.expr.get());
            if (endCount > 0) {
                for (size_t i = 0; i < endCount; ++i) {
                    patchJump(endJumps[i]);
                }
                endCount = 0;
            }
            break;
        }

        if (endCount > 0) {
            size_t nextJump = emitJump(OpCode::OP_JUMP);
            patchJump(endJumps[endCount - 1]);
            emit(OpCode::OP_POP);
            endJumps[endCount - 1] = nextJump;
        }

        emit(OpCode::OP_DUP);
        compilePattern(arm.pattern.get());
        emit(OpCode::OP_EQ);
        size_t noMatch = emitJump(OpCode::OP_JUMP_IF_FALSE);
        emit(OpCode::OP_POP);
        compileExpr(arm.expr.get());
        endJumps[endCount++] = emitJump(OpCode::OP_JUMP);
        patchJump(noMatch);
        emit(OpCode::OP_POP);
    }

    for (size_t i = 0; i < endCount; ++i) {
        patchJump(endJumps[i]);
    }
    if (!hasWildcard) {
        emit(OpCode::OP_POP);
    }
}

void Compiler::compilePattern(ast::Pattern* pat) {
    if (auto* lit = dynamic_cast<ast::LiteralPattern*>(pat)) {
        compileLiteral(lit->literal.get());
    } else if (auto* ident = dynamic_cast<ast::IdentifierPattern*>(pat)) {
        (void)ident;
        emit(OpCode::OP_NIL);
    } else if (dynamic_cast<ast::WildcardPattern*>(pat)) {
        emit(OpCode::OP_NIL);
    }
}

void Compiler::compileArray(ast::ArrayExpr* arr) {
    for (auto& elem : arr->elements) {
        compileExpr(elem.get());
    }
    emit(OpCode::OP_ARRAY);
    emit(static_cast<uint8_t>(arr->elements.size()));
}

void Compiler::compileRange(ast::RangeExpr* range) {
    compileExpr(range->start.get());
    compileExpr(range->end.get());
    emit(OpCode::OP_RANGE);
}

void Compiler::compileAssign(ast::AssignExpr* assign) {
    compileExpr(assign->value.get());
    if (auto* ident = dynamic_cast<ast::IdentifierExpr*>(assign->target.get())) {
        namedVariable(ident->name, true);
    } else if (auto* index = dynamic_cast<ast::IndexExpr*>(assign->target.get())) {
        compileExpr(index->object.get());
        compileExpr(index->index.get());
        emit(OpCode::OP_SET_INDEX);
    }
}

} // namespace r::vm
