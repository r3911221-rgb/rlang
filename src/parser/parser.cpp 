#include "parser.h"

namespace r {

Parser::Parser(std::vector<Token> tokens) : tokens_(std::move(tokens)) {}

const Token& Parser::peek(size_t offset) const {
    if (current_ + offset >= tokens_.size()) return tokens_.back();
    return tokens_[current_ + offset];
}

const Token& Parser::previous() const {
    return tokens_[current_ - 1];
}

bool Parser::isAtEnd() const {
    return peek().type == TokenType::EOF_TOKEN;
}

Token Parser::advance() {
    if (!isAtEnd()) current_++;
    return previous();
}

bool Parser::check(TokenType type) const {
    if (isAtEnd()) return false;
    return peek().type == type;
}

bool Parser::match(TokenType type) {
    if (check(type)) {
        advance();
        return true;
    }
    return false;
}

bool Parser::match(std::initializer_list<TokenType> types) {
    for (auto type : types) {
        if (check(type)) {
            advance();
            return true;
        }
    }
    return false;
}

Token Parser::consume(TokenType type, const std::string& msg) {
    if (check(type)) return advance();
    throw std::runtime_error(msg + " at line " + std::to_string(peek().line));
}

void Parser::error(const std::string& msg) {
    throw std::runtime_error("Parse error: " + msg + " at line " + std::to_string(peek().line));
}

bool Parser::canStartExpr() const {
    return check(TokenType::INT_LITERAL) || check(TokenType::FLOAT_LITERAL) ||
           check(TokenType::STRING_LITERAL) || check(TokenType::BOOL_LITERAL) ||
           check(TokenType::NIL_LITERAL) || check(TokenType::IDENTIFIER) ||
           check(TokenType::LPAREN) || check(TokenType::LBRACE) ||
           check(TokenType::LBRACKET) || check(TokenType::IF) ||
           check(TokenType::CASE) || check(TokenType::MINUS) ||
           check(TokenType::BANG) || check(TokenType::NOT) ||
           check(TokenType::BIT_NOT);
}

std::unique_ptr<ast::Program> Parser::parse() {
    return parseProgram();
}

std::unique_ptr<ast::Program> Parser::parseProgram() {
    auto program = std::make_unique<ast::Program>();
    while (!isAtEnd()) {
        program->items.push_back(parseItem());
    }
    return program;
}

std::unique_ptr<ast::Item> Parser::parseItem() {
    if (match(TokenType::DEF)) return parseFunction();
    if (match(TokenType::LET)) return parseLetItem();
    if (match(TokenType::CONST)) return parseConstItem();
    error("Expected declaration (def, let, const)");
    return nullptr;
}

std::unique_ptr<ast::FunctionItem> Parser::parseFunction() {
    auto name = consume(TokenType::IDENTIFIER, "Expected function name").text;
    consume(TokenType::LPAREN, "Expected '(' after function name");

    std::vector<ast::FunctionItem::Param> params;
    if (!check(TokenType::RPAREN)) {
        do {
            auto paramName = consume(TokenType::IDENTIFIER, "Expected parameter name").text;
            consume(TokenType::COLON, "Expected ':' after parameter name");
            auto paramType = parseType();
            params.push_back({paramName, std::move(paramType)});
        } while (match(TokenType::COMMA));
    }
    consume(TokenType::RPAREN, "Expected ')' after parameters");

    std::unique_ptr<ast::Type> returnType = nullptr;
    if (match(TokenType::ARROW)) {
        returnType = parseType();
    }

    auto body = parseBody();
    consume(TokenType::END, "Expected 'end' after function body");

    auto func = std::make_unique<ast::FunctionItem>();
    func->name = name;
    func->params = std::move(params);
    func->returnType = std::move(returnType);
    func->body = std::move(body);
    return func;
}

std::unique_ptr<ast::LetItem> Parser::parseLetItem() {
    bool isMut = match(TokenType::MUT);
    auto name = consume(TokenType::IDENTIFIER, "Expected variable name").text;

    std::unique_ptr<ast::Type> type = nullptr;
    if (check(TokenType::COLON) && peek(1).type != TokenType::ASSIGN) {
        advance();
        type = parseType();
    }

    consume(TokenType::ASSIGN, "Expected '=' after variable declaration");
    auto value = parseExpr();

    auto item = std::make_unique<ast::LetItem>();
    item->isMut = isMut;
    item->name = name;
    item->type = std::move(type);
    item->value = std::move(value);
    return item;
}

std::unique_ptr<ast::ConstItem> Parser::parseConstItem() {
    auto name = consume(TokenType::IDENTIFIER, "Expected constant name").text;

    std::unique_ptr<ast::Type> type = nullptr;
    if (check(TokenType::COLON) && peek(1).type != TokenType::ASSIGN) {
        advance();
        type = parseType();
    }

    consume(TokenType::ASSIGN, "Expected '=' after constant declaration");
    auto value = parseExpr();

    auto item = std::make_unique<ast::ConstItem>();
    item->name = name;
    item->type = std::move(type);
    item->value = std::move(value);
    return item;
}

std::unique_ptr<ast::BlockExpr> Parser::parseBody() {
    auto block = std::make_unique<ast::BlockExpr>();
    while (!check(TokenType::END) && !check(TokenType::ELSIF) &&
           !check(TokenType::ELSE) && !check(TokenType::WHEN) && !isAtEnd()) {
        block->stmts.push_back(parseStmt());
    }
    return block;
}

std::unique_ptr<ast::Expr> Parser::parseArmBody() {
    if (match(TokenType::THEN)) {
        return parseExpr();
    }
    auto block = std::make_unique<ast::BlockExpr>();
    while (!check(TokenType::WHEN) && !check(TokenType::ELSE) &&
           !check(TokenType::END) && !isAtEnd()) {
        block->stmts.push_back(parseStmt());
    }
    return block;
}

std::unique_ptr<ast::Stmt> Parser::parseStmt() {
    if (check(TokenType::LET)) return parseLetStmt();
    if (check(TokenType::CONST)) return parseConstStmt();
    if (check(TokenType::IF)) return std::make_unique<ast::ExprStmt>(parseIfExpr());
    if (check(TokenType::CASE)) return std::make_unique<ast::ExprStmt>(parseMatchExpr());
    if (check(TokenType::WHILE)) return parseWhileStmt();
    if (check(TokenType::FOR)) return parseForStmt();
    if (check(TokenType::RETURN)) return parseReturnStmt();
    if (check(TokenType::BREAK)) return parseBreakStmt();
    if (check(TokenType::CONTINUE)) return parseContinueStmt();
    return parseExprStmt();
}

std::unique_ptr<ast::LetStmt> Parser::parseLetStmt() {
    advance();
    bool isMut = match(TokenType::MUT);
    auto name = consume(TokenType::IDENTIFIER, "Expected variable name").text;

    std::unique_ptr<ast::Type> type = nullptr;
    if (check(TokenType::COLON) && peek(1).type != TokenType::ASSIGN) {
        advance();
        type = parseType();
    }

    consume(TokenType::ASSIGN, "Expected '=' after variable declaration");
    auto value = parseExpr();
    match(TokenType::SEMICOLON);

    return std::make_unique<ast::LetStmt>(isMut, name, std::move(type), std::move(value));
}

std::unique_ptr<ast::ConstStmt> Parser::parseConstStmt() {
    advance();
    auto name = consume(TokenType::IDENTIFIER, "Expected constant name").text;

    std::unique_ptr<ast::Type> type = nullptr;
    if (check(TokenType::COLON) && peek(1).type != TokenType::ASSIGN) {
        advance();
        type = parseType();
    }

    consume(TokenType::ASSIGN, "Expected '=' after constant declaration");
    auto value = parseExpr();
    match(TokenType::SEMICOLON);

    return std::make_unique<ast::ConstStmt>(name, std::move(type), std::move(value));
}

std::unique_ptr<ast::WhileStmt> Parser::parseWhileStmt() {
    advance();
    auto condition = parseExpr();
    auto body = parseBody();
    consume(TokenType::END, "Expected 'end' after while");
    auto stmt = std::make_unique<ast::WhileStmt>();
    stmt->condition = std::move(condition);
    stmt->body = std::move(body);
    return stmt;
}

std::unique_ptr<ast::ForStmt> Parser::parseForStmt() {
    advance();
    auto varName = consume(TokenType::IDENTIFIER, "Expected variable name after 'for'").text;
    consume(TokenType::IN, "Expected 'in' after variable name");
    auto iterable = parseExpr();
    auto body = parseBody();
    consume(TokenType::END, "Expected 'end' after for");
    auto stmt = std::make_unique<ast::ForStmt>();
    stmt->varName = varName;
    stmt->iterable = std::move(iterable);
    stmt->body = std::move(body);
    return stmt;
}

std::unique_ptr<ast::ReturnStmt> Parser::parseReturnStmt() {
    advance();
    std::unique_ptr<ast::Expr> value = nullptr;
    if (canStartExpr()) {
        value = parseExpr();
    }
    match(TokenType::SEMICOLON);
    return std::make_unique<ast::ReturnStmt>(std::move(value));
}

std::unique_ptr<ast::BreakStmt> Parser::parseBreakStmt() {
    advance();
    match(TokenType::SEMICOLON);
    return std::make_unique<ast::BreakStmt>();
}

std::unique_ptr<ast::ContinueStmt> Parser::parseContinueStmt() {
    advance();
    match(TokenType::SEMICOLON);
    return std::make_unique<ast::ContinueStmt>();
}

std::unique_ptr<ast::ExprStmt> Parser::parseExprStmt() {
    auto expr = parseExpr();
    match(TokenType::SEMICOLON);
    return std::make_unique<ast::ExprStmt>(std::move(expr));
}

std::unique_ptr<ast::Expr> Parser::parseExpr() {
    return parseAssignment();
}

std::unique_ptr<ast::Expr> Parser::parseAssignment() {
    auto expr = parseRange();
    if (match(TokenType::ASSIGN)) {
        auto value = parseAssignment();
        return std::make_unique<ast::AssignExpr>(std::move(expr), std::move(value));
    }
    return expr;
}

std::unique_ptr<ast::Expr> Parser::parseRange() {
    auto left = parseOr();
    if (match(TokenType::DOT_DOT)) {
        auto right = parseOr();
        return std::make_unique<ast::RangeExpr>(std::move(left), std::move(right), false);
    }
    if (match(TokenType::DOT_DOT_EQ)) {
        auto right = parseOr();
        return std::make_unique<ast::RangeExpr>(std::move(left), std::move(right), true);
    }
    return left;
}

std::unique_ptr<ast::Expr> Parser::parseOr() {
    auto expr = parseAnd();
    while (match(TokenType::OR_OR) || match(TokenType::OR)) {
        auto right = parseAnd();
        expr = std::make_unique<ast::BinaryExpr>(ast::BinaryExpr::Op::Or, std::move(expr), std::move(right));
    }
    return expr;
}

std::unique_ptr<ast::Expr> Parser::parseAnd() {
    auto expr = parseEquality();
    while (match(TokenType::AND_AND) || match(TokenType::AND)) {
        auto right = parseEquality();
        expr = std::make_unique<ast::BinaryExpr>(ast::BinaryExpr::Op::And, std::move(expr), std::move(right));
    }
    return expr;
}

std::unique_ptr<ast::Expr> Parser::parseEquality() {
    auto expr = parseComparison();
    while (true) {
        if (match(TokenType::EQ)) {
            auto right = parseComparison();
            expr = std::make_unique<ast::BinaryExpr>(ast::BinaryExpr::Op::Eq, std::move(expr), std::move(right));
        } else if (match(TokenType::NEQ)) {
            auto right = parseComparison();
            expr = std::make_unique<ast::BinaryExpr>(ast::BinaryExpr::Op::Neq, std::move(expr), std::move(right));
        } else {
            break;
        }
    }
    return expr;
}

std::unique_ptr<ast::Expr> Parser::parseComparison() {
    auto expr = parseBitwiseOr();
    while (true) {
        if (match(TokenType::LT)) {
            auto right = parseBitwiseOr();
            expr = std::make_unique<ast::BinaryExpr>(ast::BinaryExpr::Op::Lt, std::move(expr), std::move(right));
        } else if (match(TokenType::GT)) {
            auto right = parseBitwiseOr();
            expr = std::make_unique<ast::BinaryExpr>(ast::BinaryExpr::Op::Gt, std::move(expr), std::move(right));
        } else if (match(TokenType::LEQ)) {
            auto right = parseBitwiseOr();
            expr = std::make_unique<ast::BinaryExpr>(ast::BinaryExpr::Op::Leq, std::move(expr), std::move(right));
        } else if (match(TokenType::GEQ)) {
            auto right = parseBitwiseOr();
            expr = std::make_unique<ast::BinaryExpr>(ast::BinaryExpr::Op::Geq, std::move(expr), std::move(right));
        } else {
            break;
        }
    }
    return expr;
}

std::unique_ptr<ast::Expr> Parser::parseBitwiseOr() {
    auto expr = parseBitwiseXor();
    while (match(TokenType::BIT_OR)) {
        auto right = parseBitwiseXor();
        expr = std::make_unique<ast::BinaryExpr>(ast::BinaryExpr::Op::BitOr, std::move(expr), std::move(right));
    }
    return expr;
}

std::unique_ptr<ast::Expr> Parser::parseBitwiseXor() {
    auto expr = parseBitwiseAnd();
    while (match(TokenType::BIT_XOR)) {
        auto right = parseBitwiseAnd();
        expr = std::make_unique<ast::BinaryExpr>(ast::BinaryExpr::Op::BitXor, std::move(expr), std::move(right));
    }
    return expr;
}

std::unique_ptr<ast::Expr> Parser::parseBitwiseAnd() {
    auto expr = parseShift();
    while (match(TokenType::BIT_AND)) {
        auto right = parseShift();
        expr = std::make_unique<ast::BinaryExpr>(ast::BinaryExpr::Op::BitAnd, std::move(expr), std::move(right));
    }
    return expr;
}

std::unique_ptr<ast::Expr> Parser::parseShift() {
    auto expr = parseAdditive();
    while (true) {
        if (match(TokenType::SHL)) {
            auto right = parseAdditive();
            expr = std::make_unique<ast::BinaryExpr>(ast::BinaryExpr::Op::Shl, std::move(expr), std::move(right));
        } else if (match(TokenType::SHR)) {
            auto right = parseAdditive();
            expr = std::make_unique<ast::BinaryExpr>(ast::BinaryExpr::Op::Shr, std::move(expr), std::move(right));
        } else {
            break;
        }
    }
    return expr;
}

std::unique_ptr<ast::Expr> Parser::parseAdditive() {
    auto expr = parseMultiplicative();
    while (true) {
        if (match(TokenType::PLUS)) {
            auto right = parseMultiplicative();
            expr = std::make_unique<ast::BinaryExpr>(ast::BinaryExpr::Op::Add, std::move(expr), std::move(right));
        } else if (match(TokenType::MINUS)) {
            auto right = parseMultiplicative();
            expr = std::make_unique<ast::BinaryExpr>(ast::BinaryExpr::Op::Sub, std::move(expr), std::move(right));
        } else {
            break;
        }
    }
    return expr;
}

std::unique_ptr<ast::Expr> Parser::parseMultiplicative() {
    auto expr = parseUnary();
    while (true) {
        if (match(TokenType::STAR)) {
            auto right = parseUnary();
            expr = std::make_unique<ast::BinaryExpr>(ast::BinaryExpr::Op::Mul, std::move(expr), std::move(right));
        } else if (match(TokenType::SLASH)) {
            auto right = parseUnary();
            expr = std::make_unique<ast::BinaryExpr>(ast::BinaryExpr::Op::Div, std::move(expr), std::move(right));
        } else if (match(TokenType::PERCENT)) {
            auto right = parseUnary();
            expr = std::make_unique<ast::BinaryExpr>(ast::BinaryExpr::Op::Mod, std::move(expr), std::move(right));
        } else {
            break;
        }
    }
    return expr;
}

std::unique_ptr<ast::Expr> Parser::parseUnary() {
    if (match(TokenType::MINUS)) {
        auto operand = parseUnary();
        return std::make_unique<ast::UnaryExpr>(ast::UnaryExpr::Op::Neg, std::move(operand));
    }
    if (match(TokenType::BANG) || match(TokenType::NOT)) {
        auto operand = parseUnary();
        return std::make_unique<ast::UnaryExpr>(ast::UnaryExpr::Op::Not, std::move(operand));
    }
    if (match(TokenType::BIT_NOT)) {
        auto operand = parseUnary();
        return std::make_unique<ast::UnaryExpr>(ast::UnaryExpr::Op::BitNot, std::move(operand));
    }
    return parsePostfix();
}

std::unique_ptr<ast::Expr> Parser::parsePostfix() {
    auto expr = parsePrimary();

    while (true) {
        if (match(TokenType::LPAREN)) {
            std::vector<std::unique_ptr<ast::Expr>> args;
            if (!check(TokenType::RPAREN)) {
                do {
                    args.push_back(parseExpr());
                } while (match(TokenType::COMMA));
            }
            consume(TokenType::RPAREN, "Expected ')' after arguments");
            auto call = std::make_unique<ast::CallExpr>(std::move(expr));
            call->args = std::move(args);
            expr = std::move(call);
        } else if (match(TokenType::DOT)) {
            auto field = consume(TokenType::IDENTIFIER, "Expected field name after '.'").text;
            expr = std::make_unique<ast::FieldExpr>(std::move(expr), field);
        } else if (match(TokenType::LBRACKET)) {
            auto index = parseExpr();
            consume(TokenType::RBRACKET, "Expected ']' after index");
            expr = std::make_unique<ast::IndexExpr>(std::move(expr), std::move(index));
        } else {
            break;
        }
    }

    return expr;
}

std::unique_ptr<ast::Expr> Parser::parsePrimary() {
    if (match(TokenType::INT_LITERAL)) {
        return std::make_unique<ast::LiteralExpr>(ast::LiteralExpr::Kind::Int, previous().text);
    }
    if (match(TokenType::FLOAT_LITERAL)) {
        return std::make_unique<ast::LiteralExpr>(ast::LiteralExpr::Kind::Float, previous().text);
    }
    if (match(TokenType::STRING_LITERAL)) {
        return std::make_unique<ast::LiteralExpr>(ast::LiteralExpr::Kind::String, previous().text);
    }
    if (match(TokenType::BOOL_LITERAL)) {
        return std::make_unique<ast::LiteralExpr>(ast::LiteralExpr::Kind::Bool, previous().text);
    }
    if (match(TokenType::NIL_LITERAL)) {
        return std::make_unique<ast::LiteralExpr>(ast::LiteralExpr::Kind::Nil, "nil");
    }
    if (match(TokenType::IDENTIFIER)) {
        return std::make_unique<ast::IdentifierExpr>(previous().text);
    }
    if (check(TokenType::LBRACE)) {
        return parseBody();
    }
    if (match(TokenType::IF)) {
        return parseIfExpr();
    }
    if (match(TokenType::CASE)) {
        return parseMatchExpr();
    }
    if (match(TokenType::LPAREN)) {
        auto expr = parseExpr();
        consume(TokenType::RPAREN, "Expected ')' after expression");
        return expr;
    }
    if (match(TokenType::LBRACKET)) {
        return parseArrayExpr();
    }

    error("Unexpected token in expression");
    return nullptr;
}

std::unique_ptr<ast::IfExpr> Parser::parseIfExpr() {
    auto condition = parseExpr();
    auto thenBranch = parseBody();

    std::unique_ptr<ast::Expr> elseBranch = nullptr;
    if (match(TokenType::ELSIF)) {
        elseBranch = parseIfExpr();
    } else if (match(TokenType::ELSE)) {
        elseBranch = parseBody();
    }

    consume(TokenType::END, "Expected 'end' after if");

    auto expr = std::make_unique<ast::IfExpr>();
    expr->condition = std::move(condition);
    expr->thenBranch = std::move(thenBranch);
    expr->elseBranch = std::move(elseBranch);
    return expr;
}

std::unique_ptr<ast::MatchExpr> Parser::parseMatchExpr() {
    auto scrutinee = parseExpr();
    std::vector<ast::MatchExpr::Arm> arms;

    while (match(TokenType::WHEN)) {
        auto pattern = parsePattern();
        auto expr = parseArmBody();
        arms.push_back({std::move(pattern), std::move(expr)});
    }

    if (match(TokenType::ELSE)) {
        auto wildcard = std::make_unique<ast::WildcardPattern>();
        auto expr = parseArmBody();
        arms.push_back({std::move(wildcard), std::move(expr)});
    }

    consume(TokenType::END, "Expected 'end' after case");

    auto matchExpr = std::make_unique<ast::MatchExpr>();
    matchExpr->scrutinee = std::move(scrutinee);
    matchExpr->arms = std::move(arms);
    return matchExpr;
}

std::unique_ptr<ast::ArrayExpr> Parser::parseArrayExpr() {
    std::vector<std::unique_ptr<ast::Expr>> elements;
    if (!check(TokenType::RBRACKET)) {
        do {
            elements.push_back(parseExpr());
        } while (match(TokenType::COMMA));
    }
    consume(TokenType::RBRACKET, "Expected ']' after array elements");
    auto arr = std::make_unique<ast::ArrayExpr>();
    arr->elements = std::move(elements);
    return arr;
}

std::unique_ptr<ast::Pattern> Parser::parsePattern() {
    if (match(TokenType::INT_LITERAL)) {
        auto lit = std::make_unique<ast::LiteralExpr>(ast::LiteralExpr::Kind::Int, previous().text);
        return std::make_unique<ast::LiteralPattern>(std::move(lit));
    }
    if (match(TokenType::FLOAT_LITERAL)) {
        auto lit = std::make_unique<ast::LiteralExpr>(ast::LiteralExpr::Kind::Float, previous().text);
        return std::make_unique<ast::LiteralPattern>(std::move(lit));
    }
    if (match(TokenType::STRING_LITERAL)) {
        auto lit = std::make_unique<ast::LiteralExpr>(ast::LiteralExpr::Kind::String, previous().text);
        return std::make_unique<ast::LiteralPattern>(std::move(lit));
    }
    if (match(TokenType::BOOL_LITERAL)) {
        auto lit = std::make_unique<ast::LiteralExpr>(ast::LiteralExpr::Kind::Bool, previous().text);
        return std::make_unique<ast::LiteralPattern>(std::move(lit));
    }
    if (match(TokenType::NIL_LITERAL)) {
        auto lit = std::make_unique<ast::LiteralExpr>(ast::LiteralExpr::Kind::Nil, "nil");
        return std::make_unique<ast::LiteralPattern>(std::move(lit));
    }
    if (match(TokenType::MINUS)) {
        if (match(TokenType::INT_LITERAL)) {
            auto lit = std::make_unique<ast::LiteralExpr>(ast::LiteralExpr::Kind::Int, "-" + previous().text);
            return std::make_unique<ast::LiteralPattern>(std::move(lit));
        }
        if (match(TokenType::FLOAT_LITERAL)) {
            auto lit = std::make_unique<ast::LiteralExpr>(ast::LiteralExpr::Kind::Float, "-" + previous().text);
            return std::make_unique<ast::LiteralPattern>(std::move(lit));
        }
        error("Expected literal after '-' in pattern");
    }
    if (match(TokenType::IDENTIFIER)) {
        if (previous().text == "_") {
            return std::make_unique<ast::WildcardPattern>();
        }
        return std::make_unique<ast::IdentifierPattern>(previous().text);
    }

    error("Unexpected token in pattern");
    return nullptr;
}

std::unique_ptr<ast::Type> Parser::parseType() {
    auto name = consume(TokenType::IDENTIFIER, "Expected type name").text;
    return std::make_unique<ast::SimpleType>(name);
}

} // namespace r
