}

LetStmt::LetStmt(bool m, std::string n, std::unique_ptr<Type> t, std::unique_ptr<Expr> v)
    : isMut(m), name(std::move(n)), type(std::move(t)), value(std::move(v)) {}
void LetStmt::print(std::ostream& os, int indent) const {
    ind(os, indent); os << "Let(" << name << (isMut ? ", mut" : "") << ")\n";
    if (type) {
        ind(os, indent + 1); os << "Type\n";
        type->print(os, indent + 2);
    }
    ind(os, indent + 1); os << "Value\n";
    value->print(os, indent + 2);
}

ConstStmt::ConstStmt(std::string n, std::unique_ptr<Type> t, std::unique_ptr<Expr> v)
    : name(std::move(n)), type(std::move(t)), value(std::move(v)) {}
void ConstStmt::print(std::ostream& os, int indent) const {
    ind(os, indent); os << "Const(" << name << ")\n";
    if (type) {
        ind(os, indent + 1); os << "Type\n";
        type->print(os, indent + 2);
    }
    ind(os, indent + 1); os << "Value\n";
    value->print(os, indent + 2);
}

ExprStmt::ExprStmt(std::unique_ptr<Expr> e) : expr(std::move(e)) {}
void ExprStmt::print(std::ostream& os, int indent) const {
    ind(os, indent); os << "ExprStmt\n";
    expr->print(os, indent + 1);
}

void IfStmt::print(std::ostream& os, int indent) const {
    ind(os, indent); os << "IfStmt\n";
    ind(os, indent + 1); os << "Condition\n";
    condition->print(os, indent + 2);
    ind(os, indent + 1); os << "Then\n";
    thenBranch->print(os, indent + 2);
    if (elseBranch) {
        ind(os, indent + 1); os << "Else\n";
        elseBranch->print(os, indent + 2);
    }
}

void WhileStmt::print(std::ostream& os, int indent) const {
    ind(os, indent); os << "While\n";
    ind(os, indent + 1); os << "Condition\n";
    condition->print(os, indent + 2);
    ind(os, indent + 1); os << "Body\n";
    body->print(os, indent + 2);
}

void ForStmt::print(std::ostream& os, int indent) const {
    ind(os, indent); os << "For(" << varName << ")\n";
    ind(os, indent + 1); os << "Iterable\n";
    iterable->print(os, indent + 2);
    ind(os, indent + 1); os << "Body\n";
    body->print(os, indent + 2);
}

ReturnStmt::ReturnStmt(std::unique_ptr<Expr> v) : value(std::move(v)) {}
void ReturnStmt::print(std::ostream& os, int indent) const {
    ind(os, indent); os << "Return\n";
    if (value) value->print(os, indent + 1);
}

void BreakStmt::print(std::ostream& os, int indent) const {
    ind(os, indent); os << "Break\n";
}

void ContinueStmt::print(std::ostream& os, int indent) const {
    ind(os, indent); os << "Continue\n";
}

void FunctionItem::print(std::ostream& os, int indent) const {
    ind(os, indent); os << "Function(" << name << ")\n";
    if (!params.empty()) {
        ind(os, indent + 1); os << "Params\n";
        for (const auto& p : params) {
            ind(os, indent + 2); os << p.name << ": ";
            if (p.type) p.type->print(os, 0);
            else os << "auto\n";
        }
    }
    if (returnType) {
        ind(os, indent + 1); os << "ReturnType\n";
        returnType->print(os, indent + 2);
    }
    ind(os, indent + 1); os << "Body\n";
    body->print(os, indent + 2);
}

void LetItem::print(std::ostream& os, int indent) const {
    ind(os, indent); os << "LetItem(" << name << (isMut ? ", mut" : "") << ")\n";
    if (type) {
        ind(os, indent + 1); os << "Type\n";
        type->print(os, indent + 2);
    }
    ind(os, indent + 1); os << "Value\n";
    value->print(os, indent + 2);
}

void ConstItem::print(std::ostream& os, int indent) const {
    ind(os, indent); os << "ConstItem(" << name << ")\n";
    if (type) {
        ind(os, indent + 1); os << "Type\n";
        type->print(os, indent + 2);
    }
    ind(os, indent + 1); os << "Value\n";
    value->print(os, indent + 2);
}

void Program::print(std::ostream& os, int indent) const {
    ind(os, indent); os << "Program\n";
    for (const auto& item : items) {
        item->print(os, indent + 1);
    }
}

